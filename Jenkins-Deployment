pipeline {
    agent any

    parameters {
        string(name: 'DEPLOY_BRANCH', defaultValue: 'QA', description: 'Branch to deploy to QA')
    }

    stages {
        stage('Checkout Branch') {
            steps {
                git branch: "${params.DEPLOY_BRANCH}",
                    url: 'https://github.com/nishantarorasfd006-devops/salesforce-devops.git'
            }
        }

        stage('Debug CLI') {
            steps {
                bat 'sf --version'
                bat 'sf plugins'
                bat 'sf org list'
            }
        }

        stage('Deploy to QA') {
            steps {
                // 🔥 NEW COMMAND (sf syntax)
                bat 'sf project deploy start --target-org pro --source-dir force-app --test-level NoTestRun --wait 10'
            }
        }
    }

    post {
        success {
            echo 'Deployment to QA successful!'
        }
        failure {
            echo 'Deployment to QA failed!'
        }
    }
}
